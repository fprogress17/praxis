# Supabase — Project Settings → API (never commit real values)
# URL = Project URL
# Key = "anon" "public" OR newer "Publishable" / default public key (NOT service_role / secret)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local Postgres cutover target.
# Do not set this until the local schema is created and verified.
DATABASE_URL=

# Local file storage root for the post-Supabase cutover.
FILE_STORAGE_ROOT=
