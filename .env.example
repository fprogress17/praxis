# Supabase — Project Settings → API (never commit real values)
# URL = Project URL
# Key = "anon" "public" OR newer "Publishable" / default public key (NOT service_role / secret)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local Postgres cutover target.
# Do not set this until the local schema is created and verified.
DATABASE_URL=

# Local file storage root for the post-Supabase cutover.
FILE_STORAGE_ROOT=

# Optional frontend/backend split.
# Browser clients use NEXT_PUBLIC_API_BASE_URL.
# Server-side page bootstrap can use PRAXIS_API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=
PRAXIS_API_BASE_URL=

# Optional standalone-backend CORS allowlist, comma-separated.
PRAXIS_ALLOWED_ORIGINS=

# Optional standalone-backend bind and orchestration settings.
PRAXIS_BACKEND_HOST=
PRAXIS_BACKEND_PORT=
PRAXIS_BACKEND_CLIENT_HOST=
PRAXIS_RUNTIME_DIR=
PRAXIS_BACKEND_PID_FILE=
PRAXIS_BACKEND_LOG_FILE=
