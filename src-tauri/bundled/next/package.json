{
  "name": "praxis-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "backend:dev": "node --experimental-strip-types --loader ./backend/alias-loader.mjs backend/server.ts",
    "backend:start": "bash scripts/start-backend.sh",
    "backend:stop": "bash scripts/stop-backend.sh",
    "backend:status": "bash scripts/backend-status.sh",
    "backend:restart": "bash scripts/stop-backend.sh && bash scripts/start-backend.sh",
    "frontend:start": "bash scripts/start-frontend.sh",
    "frontend:stop": "bash scripts/stop-frontend.sh",
    "frontend:status": "bash scripts/frontend-status.sh",
    "frontend:restart": "bash scripts/stop-frontend.sh && bash scripts/start-frontend.sh",
    "dev:split": "bash scripts/dev-split-frontend.sh",
    "desktop:dev": "bash scripts/dev-tauri-native-managed.sh",
    "desktop:build": "NEXT_PUBLIC_API_BASE_URL= PRAXIS_API_BASE_URL= npm run build && node scripts/prepare-desktop-bundle.mjs && npm exec -- tauri build --config src-tauri/tauri.conf.json",
    "desktop:install": "node scripts/install-desktop-app.mjs",
    "desktop:dev:split": "bash scripts/dev-tauri.sh",
    "desktop:dev:scripted": "bash scripts/dev-tauri-runtime.sh",
    "desktop:dev:native": "bash scripts/dev-tauri-native-managed.sh",
    "desktop:runtime:start": "bash scripts/start-desktop-runtime.sh",
    "desktop:runtime:stop": "bash scripts/stop-desktop-runtime.sh",
    "desktop:runtime:status": "bash scripts/desktop-runtime-status.sh",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "smoke:local": "node scripts/smoke-local-runtime.mjs",
    "smoke:backend": "bash scripts/smoke-backend-orchestration.sh",
    "smoke:desktop-runtime": "bash scripts/smoke-desktop-runtime.sh",
    "supabase": "supabase",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:local:apply": "psql \"$DATABASE_URL\" -f db/local/001_init.sql",
    "db:local:export-from-supabase": "node scripts/export-supabase-data.mjs",
    "files:local:pull-from-supabase": "node scripts/download-supabase-files.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.487.0",
    "next": "^15.5.2",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.1.13",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.5.2",
    "postcss": "^8.5.6",
    "supabase": "^2.89.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2"
  }
}
